<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Bussen.Models"
             xmlns:viewmodels="clr-namespace:Bussen.ViewModels"
             xmlns:converters="clr-namespace:Bussen.Converters"
             x:Name="SharePageRoot"
             x:Class="Bussen.Views.SharePage"
             x:DataType="viewmodels:ShareViewModel"
             Shell.NavBarIsVisible="False"
             Title="SharePage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Common.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="RightBackground" BaseResourceKey="Background" TargetType="Border">
                <Setter Property="Margin" Value="10" />
                <Setter Property="WidthRequest" Value="750" />
            </Style>

            <Style x:Key="PlayerBackground" BaseResourceKey="Background" TargetType="Border">
                <Setter Property="Background" Value="#777777" />
            </Style>

            <Style x:Key="AddButton" BaseResourceKey="PositiveButton" TargetType="Button">
                <Setter Property="Margin" Value="10" />
            </Style>

            <Style x:Key="RemoveButton" BaseResourceKey="NegativeButton" TargetType="Button">
                <Setter Property="Margin" Value="10" />
            </Style>

            <Style x:Key="PlayerName" TargetType="Label">
                <Setter Property="Margin" Value="10, 0" />
                <Setter Property="FontSize" Value="23" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="PlayerLayout" TargetType="CollectionView">
                <Setter Property="HeightRequest" Value="128" />
                <Setter Property="Margin" Value="5" />
            </Style>

            <converters:PlayerCardConverter x:Key="PlayerCardConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <Grid ColumnDefinitions="*, auto"
          RowDefinitions="auto, *">
        <!-- Pyramid view -->
        <Border Grid.Column="0"
                Grid.Row="0"
                Grid.RowSpan="2"
                Margin="10"
                Style="{StaticResource Background}">
            <CollectionView Margin="10"
                            ItemsSource="{Binding Pyramid}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureAllItems"
                            VerticalOptions="Center">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="5" />
                </CollectionView.ItemsLayout>
                
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <CollectionView ItemsSource="{Binding}"
                                        SelectionMode="None"
                                        HorizontalOptions="Start">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="5" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Card">
                                    <Grid HeightRequest="{Binding Height}"
                                          WidthRequest="{Binding Width}">
                                        <Image Source="{Binding Image}"
                                               HeightRequest="{Binding Path=BindingContext.CardHeight, Source={x:Reference SharePageRoot}}"
                                               WidthRequest="{Binding Path=BindingContext.CardWidth, Source={x:Reference SharePageRoot}}"
                                               Rotation="{Binding Rotation}"
                                               Aspect="AspectFit">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer Buttons="Primary"
                                                                      Command="{Binding Path=BindingContext.TurnCardCommand, Source={x:Reference SharePageRoot}}"
                                                                      CommandParameter="{Binding .}" />

                                                <TapGestureRecognizer Buttons="Secondary"
                                                                      Command="{Binding Path=BindingContext.RotateCardCommand, Source={x:Reference SharePageRoot}}"
                                                                      CommandParameter="{Binding .}" />

                                                <!-- Could add a hold gesture from the toolkit for turning on mobile -->
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- Button layout -->
        <Border Grid.Column="1"
                Grid.Row="0"
                Style="{StaticResource RightBackground}">
            <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="auto, auto"
                  ColumnSpacing="-10"
                  RowSpacing="-10">
                <Button Grid.Column="0"
                        Grid.Row="0"
                        Text="Add Row"
                        Style="{StaticResource AddButton}"
                        Command="{Binding AddRowCommand}" />

                <Button Grid.Column="1"
                        Grid.Row="0"
                        Text="Add Card"
                        Style="{StaticResource AddButton}"
                        Command="{Binding AddCardCommand}" />

                <Button Grid.Column="0"
                        Grid.Row="1"
                        Text="Remove Row"
                        Style="{StaticResource RemoveButton}"
                        Command="{Binding RemoveRowCommand}" />

                <Button Grid.Column="1"
                        Grid.Row="1"
                        Text="Remove Card"
                        Style="{StaticResource RemoveButton}"
                        Command="{Binding RemoveCardCommand}" />

                <Button Grid.Column="2"
                        Grid.Row="0"
                        Text="To Bus"
                        Style="{StaticResource AddButton}" />

                <Border Grid.Column="2"
                        Grid.Row="1"
                        Margin="10"
                        Background="#777777"
                        StrokeShape="RoundRectangle 10">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding MatchingCard}"
                                     Value="True">
                            <Setter Property="Background" Value="#ffff00" />
                        </DataTrigger>
                    </Border.Triggers>

                    <Label Text="!"
                           FontSize="33"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#222222" />
                </Border>
            </Grid>
        </Border>

        <!-- Player cards -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Style="{StaticResource RightBackground}">
            <CollectionView ItemsSource="{Binding Players}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="5"
                                     VerticalItemSpacing="5" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Player">
                        <Border Style="{StaticResource PlayerBackground}">
                            <Grid ColumnDefinitions="auto, auto, *"
                                  RowDefinitions="auto, *">
                                <Label Grid.Column="0"
                                       Grid.Row="0"
                                       Grid.ColumnSpan="3"
                                       Style="{StaticResource PlayerName}"
                                       Text="{Binding Name}" />

                                <CollectionView Grid.Column="0"
                                                Grid.Row="1"
                                                Style="{StaticResource PlayerLayout}"
                                                ItemsSource="{Binding Cards}">
                                    <CollectionView.ItemsLayout>
                                        <LinearItemsLayout Orientation="Horizontal" />
                                    </CollectionView.ItemsLayout>

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Card">
                                            <Grid>
                                                <ImageButton Source="{Binding Image}"
                                                             Command="{Binding Path=BindingContext.RemoveMatchingCardCommand, Source={x:Reference SharePageRoot}}">
                                                    <ImageButton.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource PlayerCardConverter}">
                                                            <Binding Path="BindingContext" Source="{RelativeSource AncestorType={x:Type CollectionView}, AncestorLevel=1}" />
                                                            <Binding />
                                                        </MultiBinding>
                                                    </ImageButton.CommandParameter>
                                                </ImageButton>
                                                
                                                <Border InputTransparent="True"
                                                        Background="Transparent"
                                                        Opacity="0.3"
                                                        StrokeShape="RoundRectangle 5">
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border"
                                                                     Binding="{Binding Matches}"
                                                                     Value="True">
                                                            <Setter Property="Background" Value="#ffff00" />
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>